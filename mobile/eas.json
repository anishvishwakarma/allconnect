{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://allconnect.onrender.com",
        "EXPO_PUBLIC_USE_MOCK_OTP": "false"
      }
    },
    "production": {
      "environment": "production",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://allconnect.onrender.com",
        "EXPO_PUBLIC_USE_MOCK_OTP": "false"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
